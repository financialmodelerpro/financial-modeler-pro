# ─────────────────────────────────────────────────
# REFM Pro — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────

# ── Anthropic / Claude AI ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── NextAuth ──────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Email — Resend ───────────────────────────────
# Resend API key — get from resend.com/api-keys
RESEND_API_KEY=re_...
# Sender addresses (must be verified in Resend domain settings)
EMAIL_FROM_TRAINING=training@financialmodelerpro.com
EMAIL_FROM_NOREPLY=no-reply@financialmodelerpro.com
EMAIL_FROM_SUPPORT=support@financialmodelerpro.com
# Optional bearer secret for POST /api/email/send (used by Apps Script)
RESEND_WEBHOOK_SECRET=your-random-secret-here

# ── Public (client-safe) vars ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
